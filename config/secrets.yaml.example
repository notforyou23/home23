# Home23 secrets — API keys and tokens
# Copy this file to secrets.yaml and fill in your keys.
# This file is gitignored. Never commit secrets.yaml.

providers:
  ollama-cloud:
    apiKey: ""
  anthropic:
    apiKey: ""
  openai:
    apiKey: ""
  minimax:
    apiKey: ""
  xai:
    apiKey: ""

# Agent bot tokens are added automatically by 'home23 agent create'
# agents:
#   my-agent:
#     telegram:
#       botToken: "..."

# Shared skill credentials are host-wide. Example:
# skills:
#   x-research:
#     bearerToken: "AAAAAAAAAAAAAAAAAAAA..."

# APNs (Apple Push Notification service) — iOS app integration.
# Leave commented out if you don't run the iOS app.
# apns:
#   team_id: "ABCDE12345"            # 10-char Apple Team ID
#   key_id: "XYZABC9876"             # 10-char .p8 key ID
#   key_path: "/Users/you/secrets/AuthKey_XYZABC9876.p8"
#   bundle_id: "com.regina6.home23"
#   default_env: "production"        # TestFlight + App Store use production; local Xcode dev uses sandbox
