{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://home23.local/contracts/chat.schema.json",
  "title": "Home23 Chat Bridge Contracts",
  "$defs": {
    "startTurnResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["turn_id"],
      "properties": {
        "turn_id": { "type": "string", "minLength": 1 }
      }
    },
    "turnEnvelope": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "turn_id", "chat_id", "status", "role", "started_at"],
      "properties": {
        "type": { "type": "string", "const": "turn" },
        "turn_id": { "type": "string", "minLength": 1 },
        "chat_id": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["pending", "accepted", "running", "awaiting_model", "streaming", "tool_running", "stopping", "stopped", "complete", "error", "timeout", "orphaned"]
        },
        "role": { "type": "string" },
        "started_at": { "type": "string" },
        "ended_at": { "type": ["string", "null"] },
        "model": { "type": ["string", "null"] },
        "provider": { "type": ["string", "null"] },
        "stop_reason": { "type": ["string", "null"] },
        "error": { "type": ["string", "null"] },
        "error_code": { "type": ["string", "null"] },
        "error_message": { "type": ["string", "null"] },
        "last_seq": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "turnEvent": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "turn_id", "seq", "ts", "kind", "data"],
      "properties": {
        "type": { "type": "string", "const": "event" },
        "turn_id": { "type": "string", "minLength": 1 },
        "seq": { "type": "integer", "minimum": 0 },
        "ts": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["thinking", "tool_start", "tool_result", "response_chunk", "media", "subagent_result", "cache", "status"]
        },
        "data": {
          "type": "object",
          "additionalProperties": true,
          "required": ["type"],
          "properties": {
            "type": { "type": "string" },
            "chunk": { "type": ["string", "null"] },
            "content": { "type": ["string", "null"] },
            "tool": { "type": ["string", "null"] },
            "args": {},
            "result": { "type": ["string", "null"] },
            "success": { "type": ["boolean", "null"] },
            "mediaType": { "type": ["string", "null"] },
            "path": { "type": ["string", "null"] },
            "caption": { "type": ["string", "null"] },
            "task": { "type": ["string", "null"] },
            "status": { "type": ["string", "null"] }
          }
        }
      }
    },
    "turnStatus": {
      "type": "object",
      "additionalProperties": true,
      "required": ["turn_id", "chat_id", "status", "phase", "active", "started_at", "updated_at", "last_event_at", "last_seq", "model", "provider", "configured_default", "runtime_model", "recoverable"],
      "properties": {
        "turn_id": { "type": "string", "minLength": 1 },
        "chat_id": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["accepted", "running", "awaiting_model", "streaming", "tool_running", "stopping", "stopped", "complete", "error", "timeout", "orphaned"]
        },
        "phase": { "type": "string" },
        "active": { "type": "boolean" },
        "started_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "last_event_at": { "type": ["string", "null"] },
        "first_event_at": { "type": ["string", "null"] },
        "deadline_at": { "type": ["string", "null"] },
        "first_token_deadline_at": { "type": ["string", "null"] },
        "last_seq": { "type": ["integer", "null"], "minimum": 0 },
        "model": { "type": ["string", "null"] },
        "provider": { "type": ["string", "null"] },
        "configured_default": {
          "type": "object",
          "additionalProperties": true,
          "required": ["provider", "model"],
          "properties": {
            "provider": { "type": ["string", "null"] },
            "model": { "type": ["string", "null"] }
          }
        },
        "runtime_model": {
          "type": "object",
          "additionalProperties": true,
          "required": ["provider", "model"],
          "properties": {
            "provider": { "type": ["string", "null"] },
            "model": { "type": ["string", "null"] }
          }
        },
        "stop_requested_at": { "type": ["string", "null"] },
        "stop_reason": { "type": ["string", "null"] },
        "error_code": { "type": ["string", "null"] },
        "error_message": { "type": ["string", "null"] },
        "recoverable": { "type": "boolean" }
      }
    },
    "stopTurnRequest": {
      "type": "object",
      "additionalProperties": true,
      "required": ["chatId", "turn_id"],
      "properties": {
        "chatId": { "type": "string", "minLength": 1 },
        "turn_id": { "type": "string", "minLength": 1 }
      }
    },
    "stopTurnResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["stopped", "chatIds"],
      "properties": {
        "stopped": { "type": "boolean" },
        "chatIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "turn_id": { "type": ["string", "null"] },
        "turnId": { "type": ["string", "null"] },
        "activeTurnId": { "type": ["string", "null"] },
        "alreadyTerminal": { "type": ["boolean", "null"] },
        "status": { "type": ["string", "null"] },
        "error": { "type": ["string", "null"] }
      }
    },
    "stopTurnErrorResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["error"],
      "properties": {
        "error": { "type": "string", "minLength": 1 },
        "turn_id": { "type": ["string", "null"] },
        "chatId": { "type": ["string", "null"] },
        "activeTurnId": { "type": ["string", "null"] },
        "stopped": { "type": ["boolean", "null"] },
        "chatIds": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        }
      }
    },
    "pendingTurnsResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["pending"],
      "properties": {
        "pending": {
          "type": "array",
          "items": { "$ref": "#/$defs/turnEnvelope" }
        }
      }
    },
    "conversationSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["chatId", "count"],
      "properties": {
        "chatId": { "type": "string" },
        "count": { "type": "integer", "minimum": 0 },
        "lastTs": { "type": ["string", "null"] },
        "agent": { "type": ["string", "null"] },
        "title": { "type": ["string", "null"] }
      }
    },
    "conversationsResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["conversations"],
      "properties": {
        "conversations": {
          "type": "array",
          "items": { "$ref": "#/$defs/conversationSummary" }
        }
      }
    },
    "historyResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["chatId", "count", "total", "records"],
      "properties": {
        "chatId": { "type": "string" },
        "count": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 },
        "records": {
          "type": "array",
          "items": {
            "anyOf": [
              { "$ref": "#/$defs/turnEnvelope" },
              { "$ref": "#/$defs/turnEvent" },
              { "type": "object", "additionalProperties": true }
            ]
          }
        }
      }
    },
    "modelsResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["models"],
      "properties": {
        "models": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["alias", "provider", "model"],
            "properties": {
              "alias": { "type": "string" },
              "provider": { "type": "string" },
              "model": { "type": "string" }
            }
          }
        },
        "defaultModel": { "type": ["string", "null"] },
        "defaultProvider": { "type": ["string", "null"] }
      }
    }
  }
}
