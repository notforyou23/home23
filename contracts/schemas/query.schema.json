{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://home23.local/contracts/query.schema.json",
  "title": "Home23 Query Contracts",
  "$defs": {
    "providerCatalog": {
      "type": "object",
      "additionalProperties": true,
      "required": ["models"],
      "properties": {
        "models": {
          "type": "array",
          "items": { "$ref": "#/$defs/providerModel" }
        },
        "defaults": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "properties": {
            "queryModel": { "type": ["string", "null"] },
            "pgsSweepModel": { "type": ["string", "null"] }
          }
        }
      }
    },
    "providerModel": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": ["string", "null"] },
        "provider": { "type": ["string", "null"] }
      }
    },
    "brainRegistry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["brains"],
      "properties": {
        "brains": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "id": { "type": ["string", "null"] },
              "routeKey": { "type": ["string", "null"] },
              "name": { "type": ["string", "null"] },
              "displayName": { "type": ["string", "null"] },
              "path": { "type": ["string", "null"] },
              "sourceLabel": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "queryCatalogResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["agent", "available", "endpoints", "models", "brains", "streaming"],
      "properties": {
        "agent": { "type": ["string", "null"] },
        "available": { "type": "boolean" },
        "reason": { "type": ["string", "null"] },
        "endpoints": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "required": ["run", "stream", "export"]
        },
        "models": {
          "type": "array",
          "items": { "$ref": "#/$defs/providerModel" }
        },
        "defaults": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "properties": {
            "model": { "type": ["string", "null"] },
            "provider": { "type": ["string", "null"] },
            "mode": { "type": ["string", "null"] },
            "enablePGSByDefault": { "type": ["boolean", "null"] },
            "pgsSweepModel": { "type": ["string", "null"] },
            "pgsSweepProvider": { "type": ["string", "null"] },
            "pgsSynthModel": { "type": ["string", "null"] },
            "pgsSynthProvider": { "type": ["string", "null"] },
            "pgsDepth": { "type": ["number", "null"] }
          }
        },
        "brains": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "id": { "type": ["string", "null"] },
              "routeKey": { "type": ["string", "null"] },
              "displayName": { "type": ["string", "null"] }
            }
          }
        },
        "cosmo": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "properties": {
            "apiReachable": { "type": ["boolean", "null"] },
            "running": { "type": ["boolean", "null"] },
            "activeRun": { "type": ["boolean", "null"] }
          }
        },
        "streaming": { "type": "boolean" },
        "limits": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "lastRouteError": { "type": ["string", "null"] }
      }
    },
    "providerModelPair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "model"],
      "properties": {
        "provider": { "type": "string", "minLength": 1, "maxLength": 256 },
        "model": { "type": "string", "minLength": 1, "maxLength": 256 }
      }
    },
    "priorContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["query", "answer"],
      "properties": {
        "query": { "type": "string", "maxLength": 20000 },
        "answer": { "type": "string", "maxLength": 20000 }
      }
    },
    "queryRequest": {
      "oneOf": [
        { "$ref": "#/$defs/directQueryRequest" },
        { "$ref": "#/$defs/pgsQueryRequest" }
      ]
    },
    "directQueryRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["query"],
      "properties": {
        "agent": { "type": "string", "minLength": 1, "maxLength": 256 },
        "brainId": { "type": "string", "minLength": 1, "maxLength": 256 },
        "query": { "type": "string", "minLength": 1, "maxLength": 12000 },
        "mode": {
          "enum": ["quick", "full", "expert", "dive", "fast", "normal", "deep", "executive", "raw", "report", "innovation", "consulting", "grounded"]
        },
        "modelSelection": { "$ref": "#/$defs/providerModelPair" },
        "enablePGS": { "const": false },
        "enableSynthesis": { "type": "boolean" },
        "includeOutputs": { "type": "boolean" },
        "includeThoughts": { "type": "boolean" },
        "includeCoordinatorInsights": { "type": "boolean" },
        "allowActions": { "type": "boolean" },
        "topK": { "type": "integer", "minimum": 1, "maximum": 100 },
        "priorContext": { "$ref": "#/$defs/priorContext" },
        "dryRun": { "type": "boolean" },
        "validateOnly": { "type": "boolean" }
      }
    },
    "pgsQueryRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["query", "enablePGS"],
      "properties": {
        "agent": { "type": "string", "minLength": 1, "maxLength": 256 },
        "brainId": { "type": "string", "minLength": 1, "maxLength": 256 },
        "query": { "type": "string", "minLength": 1, "maxLength": 12000 },
        "mode": {
          "enum": ["quick", "full", "expert", "dive", "fast", "normal", "deep", "executive", "raw", "report", "innovation", "consulting", "grounded"]
        },
        "enablePGS": { "const": true },
        "pgsMode": { "enum": ["full", "continue", "targeted"] },
        "pgsConfig": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sweepFraction"],
          "properties": {
            "sweepFraction": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
          }
        },
        "pgsSweep": { "$ref": "#/$defs/providerModelPair" },
        "pgsSynth": { "$ref": "#/$defs/providerModelPair" },
        "priorContext": { "$ref": "#/$defs/priorContext" },
        "dryRun": { "type": "boolean" },
        "validateOnly": { "type": "boolean" }
      }
    },
    "queryResult": {
      "type": "object",
      "additionalProperties": true,
      "required": ["answer"],
      "properties": {
        "query": { "type": ["string", "null"] },
        "answer": { "type": "string" },
        "metadata": { "type": ["object", "null"], "additionalProperties": true },
        "actionSuggestion": { "type": ["object", "null"], "additionalProperties": true },
        "actionExecuted": { "type": ["boolean", "null"] },
        "actionError": { "type": ["string", "null"] },
        "actionResult": { "type": ["object", "null"], "additionalProperties": true },
        "exportedTo": { "type": ["string", "null"] }
      }
    },
    "operationId": {
      "type": "string",
      "pattern": "^brop_[A-Za-z0-9_-]{32,}$"
    },
    "resultHandle": {
      "type": ["string", "null"],
      "pattern": "^brres_[A-Za-z0-9_-]{32,}$"
    },
    "structuredError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "retryable": { "type": "boolean" }
      }
    },
    "operationGuidance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resume", "status", "result", "cancel"],
      "properties": {
        "resume": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "result": { "type": "string", "minLength": 1 },
        "cancel": { "type": "string", "minLength": 1 }
      }
    },
    "resultArtifact": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "sourceEvidence": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "queryRunResponse": {
      "oneOf": [
        { "$ref": "#/$defs/queryTerminalSuccess" },
        { "$ref": "#/$defs/queryDetached" },
        { "$ref": "#/$defs/queryFailure" },
        { "$ref": "#/$defs/queryDryRun" }
      ]
    },
    "queryTerminalSuccess": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "operationId", "state", "attachmentState", "detached", "resultHandle", "resultArtifact", "sourceEvidence", "result", "answer"],
      "properties": {
        "type": { "const": "result" },
        "ok": { "const": true },
        "operationId": { "$ref": "#/$defs/operationId" },
        "state": { "enum": ["complete", "partial"] },
        "attachmentState": { "const": "closed" },
        "detached": { "const": false },
        "resultHandle": { "$ref": "#/$defs/resultHandle" },
        "resultArtifact": { "$ref": "#/$defs/resultArtifact" },
        "sourceEvidence": { "$ref": "#/$defs/sourceEvidence" },
        "result": { "$ref": "#/$defs/queryResult" },
        "answer": { "type": "string", "minLength": 1 },
        "query": { "type": "string" },
        "metadata": { "type": ["object", "null"], "additionalProperties": true }
      }
    },
    "queryDetached": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "operationId", "state", "attachmentState", "detached", "guidance"],
      "properties": {
        "type": { "const": "detached" },
        "ok": { "const": false },
        "operationId": { "$ref": "#/$defs/operationId" },
        "state": { "enum": ["queued", "running"] },
        "attachmentState": { "const": "detached" },
        "detached": { "const": true },
        "guidance": { "$ref": "#/$defs/operationGuidance" }
      }
    },
    "queryFailure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "error"],
      "properties": {
        "ok": { "const": false },
        "error": { "$ref": "#/$defs/structuredError" }
      }
    },
    "queryDryRun": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "dryRun", "result"],
      "properties": {
        "ok": { "const": true },
        "dryRun": { "const": true },
        "result": { "$ref": "#/$defs/queryResult" }
      }
    },
    "queryExportResponse": {
      "oneOf": [
        { "$ref": "#/$defs/queryExportSuccess" },
        { "$ref": "#/$defs/queryExportDetached" },
        { "$ref": "#/$defs/queryExportFailure" },
        { "$ref": "#/$defs/queryExportDryRun" }
      ]
    },
    "queryExportSuccess": {
      "type": "object",
      "additionalProperties": false,
      "required": ["success"],
      "properties": {
        "success": { "const": true },
        "operationId": { "$ref": "#/$defs/operationId" },
        "state": { "enum": ["complete", "partial"] },
        "resultHandle": { "$ref": "#/$defs/resultHandle" },
        "canonicalEvidence": { "type": "boolean" },
        "exportedTo": { "type": "string", "minLength": 1 },
        "exportHandle": { "type": "string", "minLength": 1 },
        "relativePath": { "type": "string", "minLength": 1 },
        "bytes": { "type": "integer", "minimum": 0 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "sourceOperationId": { "type": ["string", "null"] },
        "sourceResultHandleHash": { "type": ["string", "null"] },
        "format": { "enum": ["markdown", "json", "jsonl"] }
      }
    },
    "queryExportDetached": {
      "type": "object",
      "additionalProperties": false,
      "required": ["success", "ok", "operationId", "state", "attachmentState", "detached", "guidance", "canonicalEvidence"],
      "properties": {
        "success": { "const": false },
        "ok": { "const": false },
        "operationId": { "$ref": "#/$defs/operationId" },
        "state": { "enum": ["queued", "running"] },
        "attachmentState": { "const": "detached" },
        "detached": { "const": true },
        "guidance": { "$ref": "#/$defs/operationGuidance" },
        "canonicalEvidence": { "const": false }
      }
    },
    "queryExportFailure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["success", "error"],
      "properties": {
        "success": { "const": false },
        "error": { "$ref": "#/$defs/structuredError" }
      }
    },
    "queryExportDryRun": {
      "type": "object",
      "additionalProperties": false,
      "required": ["success", "dryRun", "canonicalEvidence", "exportedTo", "query", "answer", "format", "metadata"],
      "properties": {
        "success": { "const": true },
        "dryRun": { "const": true },
        "canonicalEvidence": { "type": "boolean" },
        "exportedTo": { "type": "null" },
        "query": { "type": "string" },
        "answer": { "type": "string" },
        "format": { "enum": ["markdown", "json", "jsonl"] },
        "metadata": { "type": ["object", "null"], "additionalProperties": true }
      }
    },
    "streamEvent": {
      "oneOf": [
        { "$ref": "#/$defs/streamStatusEvent" },
        { "$ref": "#/$defs/streamResultEvent" },
        { "$ref": "#/$defs/streamDetachedEvent" },
        { "$ref": "#/$defs/streamErrorEvent" }
      ]
    },
    "streamStatusEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "operationId", "state", "phase", "eventSequence", "updatedAt"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "operationId": { "$ref": "#/$defs/operationId" },
        "state": { "type": ["string", "null"] },
        "phase": { "type": ["string", "null"] },
        "eventSequence": { "type": "integer", "minimum": 0 },
        "updatedAt": { "type": ["string", "null"] }
      }
    },
    "streamResultEvent": {
      "allOf": [
        { "$ref": "#/$defs/queryTerminalSuccess" },
        {
          "type": "object",
          "required": ["type"],
          "properties": { "type": { "const": "result" } }
        }
      ]
    },
    "streamDetachedEvent": {
      "allOf": [
        { "$ref": "#/$defs/queryDetached" },
        {
          "type": "object",
          "required": ["type"],
          "properties": { "type": { "const": "detached" } }
        }
      ]
    },
    "streamErrorEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "ok", "error"],
      "properties": {
        "type": { "const": "error" },
        "ok": { "const": false },
        "error": { "$ref": "#/$defs/structuredError" }
      }
    }
  }
}
