{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://home23.local/contracts/agent-roster.schema.json",
  "title": "Home23 Agent Roster",
  "allOf": [
    { "$ref": "#/$defs/agentRosterResponse" }
  ],
  "$defs": {
    "agentRosterResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["agents"],
      "properties": {
        "agents": {
          "type": "array",
          "items": { "$ref": "#/$defs/agent" }
        },
        "currentAgent": { "type": ["string", "null"] },
        "primaryAgent": { "type": ["string", "null"] }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "displayName": { "type": ["string", "null"] },
        "model": { "type": ["string", "null"] },
        "provider": { "type": ["string", "null"] },
        "owner": { "type": ["string", "null"] },
        "timezone": { "type": ["string", "null"] },
        "status": { "type": ["string", "null"] },
        "isPrimary": { "type": "boolean" },
        "ports": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "properties": {
            "bridge": { "type": ["integer", "null"], "minimum": 1 },
            "dashboard": { "type": ["integer", "null"], "minimum": 1 },
            "engine": { "type": ["integer", "null"], "minimum": 1 },
            "mcp": { "type": ["integer", "null"], "minimum": 1 }
          }
        }
      }
    }
  }
}
