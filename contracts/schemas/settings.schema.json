{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://home23.local/contracts/settings.schema.json",
  "title": "Home23 Settings Control Plane",
  "$defs": {
    "status": {
      "type": "object",
      "additionalProperties": true,
      "required": ["hasAgents", "agentCount", "initialized"],
      "properties": {
        "hasAgents": { "type": "boolean" },
        "agentCount": { "type": "integer", "minimum": 0 },
        "initialized": { "type": "boolean" },
        "currentAgent": { "type": ["string", "null"] },
        "primaryAgent": { "type": ["string", "null"] },
        "scopeRegistryVersion": { "type": ["integer", "null"] }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": true,
      "required": ["version", "tabs", "agents"],
      "properties": {
        "version": { "type": "integer" },
        "currentAgent": { "type": ["string", "null"] },
        "primaryAgent": { "type": ["string", "null"] },
        "selectedAgent": { "type": ["string", "null"] },
        "tabs": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true,
            "required": ["kind", "chip", "agentTarget", "summaryTemplate"],
            "properties": {
              "kind": { "type": "string" },
              "chip": { "type": "string" },
              "agentTarget": { "type": "string" },
              "summaryTemplate": { "type": "string" }
            }
          }
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["name", "isPrimary", "isCurrentDashboard"],
            "properties": {
              "name": { "type": "string" },
              "displayName": { "type": ["string", "null"] },
              "isPrimary": { "type": "boolean" },
              "isCurrentDashboard": { "type": "boolean" }
            }
          }
        }
      }
    },
    "queryDefaults": {
      "type": "object",
      "additionalProperties": true,
      "required": ["defaultModel", "defaultMode", "enablePGSByDefault", "pgsSweepModel", "pgsSynthModel", "pgsDepth"],
      "properties": {
        "agent": { "type": ["string", "null"] },
        "defaultModel": { "type": "string" },
        "defaultProvider": { "type": ["string", "null"] },
        "defaultMode": { "type": "string" },
        "enablePGSByDefault": { "type": "boolean" },
        "pgsSweepModel": { "type": "string" },
        "pgsSweepProvider": { "type": ["string", "null"] },
        "pgsSynthModel": { "type": "string" },
        "pgsSynthProvider": { "type": ["string", "null"] },
        "pgsDepth": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "modelsResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["agent", "chat", "aliases"],
      "properties": {
        "agent": { "type": ["string", "null"] },
        "currentAgent": { "type": ["string", "null"] },
        "primaryAgent": { "type": ["string", "null"] },
        "chat": {
          "type": "object",
          "additionalProperties": true,
          "required": ["defaultProvider", "defaultModel"],
          "properties": {
            "defaultProvider": { "type": ["string", "null"] },
            "defaultModel": { "type": ["string", "null"] }
          }
        },
        "aliases": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true,
            "required": ["provider", "model"],
            "properties": {
              "provider": { "type": "string" },
              "model": { "type": "string" }
            }
          }
        },
        "providers": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "engineRoles": {
          "type": ["object", "null"],
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "saveResponse": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "ok": { "type": ["boolean", "null"] },
        "error": { "type": ["string", "null"] }
      }
    }
  }
}
