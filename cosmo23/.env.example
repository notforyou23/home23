# COSMO 2.3 standalone defaults

# App ports
COSMO23_PORT=43110
COSMO23_WS_PORT=43140
COSMO23_DASHBOARD_PORT=43144
COSMO23_MCP_HTTP_PORT=43147

# Local Prisma DB
DATABASE_URL=file:./prisma/cosmo2.3.db

# Optional reference brain scan roots
COSMO_REFERENCE_RUNS_PATHS=

# Optional custom model catalog location
# COSMO23_MODEL_CATALOG_PATH=/Users/you/.cosmo2.3/model-catalog.json

# OpenAI
# Keep OpenAI configured if you want full brain-memory embeddings and semantic query.
OPENAI_API_KEY=

# Anthropic — OAuth only (no API key). Use "Import from Claude CLI" or the OAuth flow in the web UI.

# xAI
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

# Local LLM endpoints
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=qwen3.5:14b
LOCAL_LLM_FAST_MODEL=qwen2.5-coder:7b
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Optional security override for config encryption
# ENCRYPTION_KEY=
