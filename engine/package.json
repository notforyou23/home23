{
  "name": "cosmo",
  "version": "3.0.0",
  "description": "COSMO - Autonomous AI Research System",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:all": "./scripts/START_ALL.sh",
    "setup": "bash scripts/setup.sh",
    "stop": "./scripts/STOP_ALL.sh",
    "status": "./scripts/STATUS_ALL.sh",
    "clean": "./scripts/CLEAN_RESTART.sh",
    "backup": "./scripts/CLEAN_RESTART.sh",
    "restore": "./scripts/RESTORE_BACKUP.sh",
    "mcp:http": "node mcp/http-server.js",
    "mcp:stdio": "node mcp/stdio-server.js",
    "mcp:fs": "node mcp/filesystem-server.js",
    "mcp:dashboard": "node mcp/dashboard-server.js",
    "test:mcp": "node mcp/test.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "mocha tests/unit/**/*.test.js --timeout 10000",
    "test:integration": "mocha tests/integration/**/*.test.js --timeout 30000",
    "test:agents": "mocha tests/agents/agent-structure-validation.test.js --timeout 10000 --reporter json > test-results/agents.json || mocha tests/agents/agent-structure-validation.test.js --timeout 10000",
    "test:agents:execution": "mocha tests/agents/code-execution-validation.test.js tests/agents/code-creation-validation.test.js --timeout 120000",
    "test:single-instance": "npm run test:unit && mocha tests/single-instance/**/*.test.js --timeout 60000",
    "test:multi-instance": "mocha tests/multi-instance/**/*.test.js --timeout 120000",
    "test:acceptance": "mocha tests/acceptance/**/*.acceptance.js --timeout 120000",
    "test:acceptance:phase-a": "mocha tests/acceptance/phase-a.acceptance.js --timeout 120000",
    "test:acceptance:phase-b-r": "mocha tests/acceptance/phase-b-r.acceptance.js --timeout 120000",
    "test:acceptance:phase-b-fs": "mocha tests/acceptance/phase-b-fs.acceptance.js --timeout 120000",
    "test:full": "npm run test:single-instance && npm run test:multi-instance && npm run test:acceptance",
    "test:baseline": "node tests/scripts/capture-baseline.js",
    "ip:snapshot": "node scripts/create-ip-snapshot.js"
  },
  "keywords": [
    "ai",
    "autonomous",
    "research",
    "cognitive-architecture",
    "multi-provider",
    "mcp"
  ],
  "author": "",
  "license": "ISC",
  "bin": {
    "ask": "./ask"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@modelcontextprotocol/sdk": "^1.19.1",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@prisma/client": "^7.5.0",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "gradient-string": "^1.2.0",
    "hnswlib-node": "^3.0.0",
    "ioredis": "^5.8.1",
    "js-yaml": "^4.1.0",
    "lockfile": "^1.0.4",
    "mammoth": "^1.11.0",
    "openai": "^6.0.1",
    "ora": "^5.4.1",
    "pdf-parse": "^2.4.5",
    "screenshot-desktop": "^1.15.3",
    "tiktoken": "^1.0.22",
    "ulid": "^3.0.1",
    "uuid": "^13.0.0",
    "ws": "^8.18.3",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "chai": "^4.5.0",
    "messagepack": "^1.1.12",
    "mocha": "^10.8.2",
    "msgpackr": "^1.11.5",
    "sinon": "^15.2.0"
  }
}
